{
  "name": "branch-titlebar",
  "displayName": "Branch Title Bar Color",
  "description": "Automatically colorizes title bar based on git branch",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "branchTitleBar.updateColor",
        "title": "Branch Title Bar: Update Color"
      }
    ],
    "configuration": {
      "title": "Branch Title Bar Color",
      "properties": {
        "branchTitleBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic title bar coloring based on branch"
        },
        "branchTitleBar.saturation": {
          "type": "number",
          "default": 45,
          "minimum": 0,
          "maximum": 100,
          "description": "Color saturation percentage (0-100)"
        },
        "branchTitleBar.lightness": {
          "type": "number",
          "default": 33,
          "minimum": 0,
          "maximum": 100,
          "description": "Color lightness percentage (0-100)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.x",
    "@types/vscode": "^1.60.0",
    "typescript": "^4.7.4"
  }
}
